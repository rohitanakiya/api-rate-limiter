REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
ADMIN_API_KEY=change-this-to-a-strong-secret
APP_NAME=API Rate Limiter
DEBUG=False

# Gateway / proxy mode (optional)
# When set, requests to /gw/{path} are authenticated, rate-limited,
# then forwarded to UPSTREAM_URL/{path}.
UPSTREAM_URL=
PROXY_REQUEST_TIMEOUT=30.0
